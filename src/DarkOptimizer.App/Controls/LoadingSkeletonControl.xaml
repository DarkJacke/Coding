<UserControl
    x:Class="DarkOptimizer.App.Controls.LoadingSkeletonControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid MinHeight="140" CornerRadius="12" Background="#22FFFFFF" Padding="16">
        <StackPanel Spacing="10">
            <Rectangle Height="16" RadiusX="8" RadiusY="8" Fill="#30FFFFFF" />
            <Rectangle Height="16" RadiusX="8" RadiusY="8" Fill="#25FFFFFF" />
            <Rectangle Height="16" RadiusX="8" RadiusY="8" Fill="#20FFFFFF" />
        </StackPanel>
    </Grid>
</UserControl>
