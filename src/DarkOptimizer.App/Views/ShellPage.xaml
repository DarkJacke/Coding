<Page
    x:Class="DarkOptimizer.App.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:DarkOptimizer.App.Controls"
    xmlns:vm="using:DarkOptimizer.App.ViewModels"
    mc:Ignorable="d"
    Background="{ThemeResource AppBackgroundBrush}">

    <Page.Resources>
        <x:String x:Key="CaptionFont">Bahnschrift SemiBold</x:String>
    </Page.Resources>

    <Grid x:Name="RootGrid" Padding="20" RowSpacing="12" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="12" CornerRadius="16" Background="#26000000">
            <StackPanel Spacing="8">
                <TextBlock Text="Dark optimizer 2026" FontSize="22" FontFamily="{StaticResource CaptionFont}"/>
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.SidebarItems, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:NavItemViewModel">
                            <Button HorizontalAlignment="Stretch" Click="OnNavigationClicked" Tag="{x:Bind Route}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="{x:Bind Glyph}"/>
                                    <TextBlock Text="{x:Bind Label}"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="14">
                <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}" FontSize="28" FontFamily="{StaticResource CaptionFont}" />
                <TextBlock VerticalAlignment="Bottom" Text="{x:Bind ViewModel.MemorySummary, Mode=OneWay}" Opacity="0.8" />
            </StackPanel>

            <Grid Grid.Row="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <controls:LoadingSkeletonControl x:Load="{x:Bind ViewModel.IsDashboardLoading, Mode=OneWay}" />

                <StackPanel Grid.Row="1" x:Load="{x:Bind ViewModel.IsAdvancedLoaded, Mode=OneWay}" Spacing="12">
                    <Border CornerRadius="12" Padding="14" Background="#22FFFFFF">
                        <StackPanel>
                            <TextBlock Text="Optimization Tiers" FontSize="18" />
                            <TextBlock Text="Simple • Intermediate • Advanced • Supervised" Opacity="0.85" />
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="12" Padding="14" Background="#22FFFFFF">
                        <StackPanel>
                            <TextBlock Text="Free RAM" FontSize="18" />
                            <TextBlock Text="Mem Reduct-style: working set trim + standby purge + low-priority standby purge." TextWrapping="WrapWholeWords" Opacity="0.85"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
